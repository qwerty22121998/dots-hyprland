    "hyprland/window": {
        "separate-outputs": true,
        "format": "{class}",
        "icon": true,
        "icon-size": 16,
        "max-length": 50,
        "rewrite": {}
    },
    "hyprland/windowcount": {
        "format": "[{}]",
        "format-empty": "[X]",
        "format-windowed": "[T]",
        // "format-fullscreen": "[{}]",
        "separate-outputs": true
    }
