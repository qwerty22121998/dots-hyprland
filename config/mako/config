max-history=10
sort=-time
font=JetBrainsMono Nerd Font 14
width=400
height=100
padding=5,10
border-size=0
max-icon-size=32
icons=1
icon-location=left
#format=<b>%s</b>\n%b Default when grouped: (%g) <b>%s</b>\n%b
format=%s\n%b
text-alignment=center
default-timeout=5000
anchor=top-center

include=~/.config/mako/color.conf

[urgency=normal]
border-size=2

[urgency=critical]
border-size=2
default-timeout=0
